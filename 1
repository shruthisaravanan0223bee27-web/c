#include<stdio.h>
int main()
{
   int a[30];
   int i,n;
   printf("enter the number of cadets:");
   scanf("%d",&n);
   for(i=0;i<=n-1;i++)
   {
      printf("enter the roll number%d:",i+1);
      scanf("%d",&a[i]);
   }
   printf("they are marching in order:\n");
   for(i=n-1;i>=0;i--)
   {
      printf("%d\n",a[i]);
   }
}
